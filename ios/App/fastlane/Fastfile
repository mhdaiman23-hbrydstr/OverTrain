# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Get team ID and API key info from environment
    team_id = ENV["TEAM_ID"]
    api_key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    api_key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
    api_issuer_id = ENV["APP_STORE_CONNECT_API_ISSUER_ID"]

    # Setup code signing with Match
    match(
      type: "appstore",
      readonly: true,  # Don't create new certificates, just fetch existing ones
      app_identifier: "app.overtrain.gooonemore"
    )

    # Configure code signing settings to use Match certificates
    update_code_signing_settings(
      use_automatic_signing: false,  # Use manual signing with Match
      team_id: team_id,
      path: "App.xcodeproj",
      code_sign_identity: "iPhone Distribution",  # Use the Match certificate
      profile_name: "match AppStore app.overtrain.gooonemore"  # Use the Match profile
    )

    # Build the app
    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "../build",
      output_name: "OverTrain.ipa",
      include_symbols: true,
      include_bitcode: false,
      export_options: {
        teamID: team_id,
        method: "app-store",
        signingStyle: "manual",  # Use manual signing
        provisioningProfiles: {
          "app.overtrain.gooonemore" => "match AppStore app.overtrain.gooonemore"
        }
      }
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      notify_external_testers: false,
      changelog: default_changelog
    )
  end

  desc "Build for ad-hoc distribution"
  lane :adhoc do
    # Get team ID from environment
    team_id = ENV["TEAM_ID"]

    # Configure code signing settings in Xcode project
    update_code_signing_settings(
      use_automatic_signing: true,
      team_id: team_id,
      path: "App.xcodeproj"
    )

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "ad-hoc",
      output_directory: "../build",
      output_name: "OverTrain-AdHoc.ipa",
      include_symbols: true,
      include_bitcode: false,
      xcargs: "-allowProvisioningUpdates",
      export_options: {
        teamID: team_id,
        method: "ad-hoc",
        signingStyle: "automatic",
        provisioningProfiles: {}
      }
    )
  end

  private_lane :default_changelog do
    # Get the latest commit message for changelog
    changelog = last_git_commit[:message]
    if changelog.length > 200
      changelog = changelog[0, 200] + "..."
    end
    changelog
  end
end
